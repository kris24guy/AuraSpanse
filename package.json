  }
}
Then run:

npm install
2. Minimal working server
Start with this tiny server first so you know deploys will work before adding aura logic:

// server.js
const express = require('express');
const app = express();

app.get('/', (req, res) => {
  res.send('Aurascope backend is alive');
});

const PORT = process.env.PORT || 3000;
app.listen(PORT, () => {
  console.log('Aurascope running on port', PORT);
});
